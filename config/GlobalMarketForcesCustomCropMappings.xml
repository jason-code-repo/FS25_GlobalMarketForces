    <crop alias="grain corn" referenceCrop="MAIZE" profileGroup="grain"/>
    <crop alias="grain maize" referenceCrop="MAIZE" profileGroup="grain"/>
    <crop alias="sweet corn" referenceCrop="MAIZE" profileGroup="grain"/>
