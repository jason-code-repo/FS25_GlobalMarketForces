<?xml version="1.0" encoding="utf-8"?>
<!--
    Global Market Forces custom crop compatibility mappings.

    Aliases are case-insensitive and GMF removes spaces, punctuation, and
    separators before matching. For example: Rye, RYE, and Rye; all match rye.
    referenceCrop supplies the market profile, seasonal curve, named crop
    trends, and world-event exposure for the detected custom fruit type.
-->
<customCropMappings>
    <!-- Wheat-family cereals -->
    <crop alias="rye" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="winter rye" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="spring rye" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="spelt" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="dinkel" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="triticale" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="durum" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="durum wheat" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="emmer" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="farro" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="einkorn" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="kamut" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="khorasan" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="buckwheat" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="winter wheat" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="spring wheat" referenceCrop="WHEAT" profileGroup="grain"/>
    <crop alias="summer wheat" referenceCrop="WHEAT" profileGroup="grain"/>

    <!-- Barley and oats -->
